{
  "name": "@gigo-ui/components",
  "version": "1.0.0-alpha",
  "description": "Deliberately dysfunctional UI components — technically excellent, intentionally terrible UX",
  "license": "MIT",
  "type": "module",
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./globals.css": "./dist/styles/globals.css"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:lib": "svelte-kit sync && svelte-package && publint",
    "preview": "vite preview",
    "prepare": "svelte-kit sync ",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "package": "svelte-kit sync && svelte-package"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@threlte/core": "^8.4.1",
    "@types/three": "^0.183.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "publint": "^0.3.18",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "keywords": [
    "svelte",
    "ui-components",
    "educational",
    "ux-antipatterns",
    "design-system",
    "tailwindcss"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
